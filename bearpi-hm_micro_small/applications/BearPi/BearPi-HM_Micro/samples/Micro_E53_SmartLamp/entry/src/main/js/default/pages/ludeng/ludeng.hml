<div class="container">
    <div class="header">
        <text class="title">智慧台灯</text>
    </div>
    <div class="content">
        <text class="status">状态: {{mydata.LED}}</text>
        <text class="lux">光照: {{mydata.Lux}} lx</text>
        <text class="brightness">亮度: {{mydata.Brightness}}%</text>
        <div class="btn" onclick="toggleLight">
            <text class="btn-text">{{mydata.LED == 'ON' ? '关灯' : '开灯'}}</text>
        </div>
    </div>
</div>
